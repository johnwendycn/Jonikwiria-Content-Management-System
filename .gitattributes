# Normalize line endings to LF on commit, checkout as LF on all platforms
* text=auto eol=lf

# Explicitly set binary files (never normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.pdf binary
*.zip binary
*.sqlite binary
*.sqlite3 binary
*.db binary
