# Backend environment variables — copy this to `.env` and fill in your values.
# Never commit the actual .env file to version control.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Option A: PostgreSQL (recommended for production)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=jonikwiria_cms
# DB_USER=postgres
# DB_PASS=yourpassword
# DB_SSL=false

# Option B: PostgreSQL connection URL
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/jonikwiria_cms

# Leave all DB_* variables commented out to use the local SQLite fallback
# (backend/database.sqlite — auto-created on first run)

# ─── Security ─────────────────────────────────────────────────────────────────
# SESSION_SECRET=change-me-to-a-long-random-string
# JWT_SECRET=change-me-to-another-long-random-string

# ─── Optional SMTP (for real email delivery) ──────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=yoursmtppassword
# SMTP_FROM="Jonikwiria CMS <noreply@example.com>"
